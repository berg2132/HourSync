# MongoDB Atlas
# Como obter: mongodb.com/cloud/atlas -> Create Cluster -> Connect -> Drivers
# Formato: mongodb+srv://usuario:senha@cluster.mongodb.net/hoursync
MONGODB_URI=<<PREENCHER COM SUA URI DO MONGODB ATLAS>>

# JWT - pode deixar esse valor ou trocar por qualquer texto longo
JWT_SECRET=hoursync_jwt_secret_2026_muito_seguro
JWT_EXPIRES_IN=1d

# Upload de arquivos - nao precisa mudar
UPLOAD_DIR=uploads

# E-mail - ja preenchido com os dados do projeto
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=hoursync.sistema@gmail.com
MAIL_PASS=hrebegobhrfqkoaz

# Porta do servidor - nao precisa mudar
PORT=8080
CORS_ORIGIN=*
